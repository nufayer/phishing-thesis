# ============================================================
# PhishShield AI - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values
# ============================================================

# Flask
FLASK_ENV=production
SECRET_KEY=your-super-secret-key-change-in-production
FLASK_DEBUG=False

# Model (REQUIRED for Render free tier - model downloads at startup)
# Get this from GitHub Release, Google Drive, S3, Hugging Face, etc.
MODEL_URL=https://github.com/yourusername/phishing-thesis/releases/download/v1.0/ensemble_final.pkl

# Render sets this automatically
# PORT=10000

# Optional: Logging
LOG_LEVEL=INFO

# Optional: External APIs (for enhanced features)
# VIRUSTOTAL_API_KEY=
# GOOGLE_SAFE_BROWSING_KEY=
# URLSCAN_API_KEY=

# ============================================================
# Development overrides (uncomment for local dev)
# ============================================================
# FLASK_ENV=development
# FLASK_DEBUG=True
# MODEL_URL=http://localhost:8000/models/ensemble_final.pkl